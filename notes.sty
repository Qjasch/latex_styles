\pgfplotsset{compat=1.18}

\newfontfamily{\rawtitlefont}{Futura}[Scale=0.9]
\setmainfont{Minion Pro}[LetterSpace=1.0, Ligatures=NoCommon]
\newcommand{\titlefont}[1]{{\rawtitlefont\textcolor[HTML]{222222}{#1}}}

\newcommand{\stdtitle}[3]{\setstretch{1.6}
\titlefont{\LARGE #1} \\
\titlefont{\LARGE #2}\\
\titlefont{\Large#3}\\
\vspace{10pt}}

\titleformat{\section}{\rawtitlefont\color[HTML]{222222}\Large}{\thesection}{1em}{}
\titleformat{\subsection}{\rawtitlefont\color[HTML]{222222}\large}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\rawtitlefont\color[HTML]{222222}\normalsize}{\thesubsubsection}{1em}{}

\setlist[enumerate]{font=\titlefont, leftmargin=2.1em, labelwidth=0em, align=right, labelsep=1.1em}

\pagestyle{fancy}
\fancyhead{}
\fancyfoot{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}


\newcommand\SET[2]{\{\,#1\mid#2\,\}}
