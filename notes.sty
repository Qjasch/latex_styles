\newcommand{\titlefont}[1]{{\rawtitlefont\textcolor[HTML]{222222}{#1}}}

\newcommand*\squeezespaces[1] {
  \thickmuskip=\scalemuskip{\thickmuskip}{#1}%
  \medmuskip=\scalemuskip{\medmuskip}{#1}%
  \thinmuskip=\scalemuskip{\thinmuskip}{#1}%
  \nulldelimiterspace=#1\nulldelimiterspace
  \scriptspace=#1\scriptspace
}

% based on https://tex.stackexchange.com/a/198966/156366
\newcommand*\scalemuskip[2]{%
  \muexpr #1*\numexpr\dimexpr#2pt\relax\relax/65536\relax
} 


\@ifclassloaded{beamer}{}{%
  \newcommand{\stdtitle}[3]{\setstretch{1.6}
  \titlefont{\LARGE #1} \\
  \titlefont{\LARGE #2}\\
  \titlefont{\Large#3}\\
  \vspace{10pt}}

  \titleformat{\section}{\rawtitlefont\color[HTML]{222222}\Large}{\thesection}{1em}{}
  \titleformat{\subsection}{\rawtitlefont\color[HTML]{222222}\large}{\thesubsection}{1em}{}
  \titleformat{\subsubsection}{\rawtitlefont\color[HTML]{222222}\normalsize}{\thesubsubsection}{1em}{}
}

